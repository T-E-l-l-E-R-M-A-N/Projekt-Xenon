<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AccentBrush" Color="DeepPink"/>
    <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="Gray"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="Black"/>
    <SolidColorBrush x:Key="SecondaryForegroundBrush" Color="LightGray"/>
</ResourceDictionary>
