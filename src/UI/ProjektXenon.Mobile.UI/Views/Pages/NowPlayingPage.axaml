<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:ProjektXenon.Shared.ViewModels;assembly=ProjektXenon.Shared"
             xmlns:views="clr-namespace:ProjektXenon.Mobile.UI.Views"
             xmlns:avalonia="https://github.com/projektanker/icons.avalonia"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             xmlns:valueConverters="clr-namespace:ProjektXenon.Mobile.UI.ValueConverters"
             xmlns:models="clr-namespace:ProjektXenon.Shared.Models;assembly=ProjektXenon.Shared"
             xmlns:behaviors="clr-namespace:ProjektXenon.Mobile.UI.Behaviors"
             xmlns:shared="clr-namespace:ProjektXenon.Shared;assembly=ProjektXenon.Shared"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="ProjektXenon.Mobile.UI.Views.NowPlayingPage"
             x:DataType="viewModels:NowPlayingPageViewModel">
    <UserControl.Styles>
        <Style Selector="TabControl.PageTabsView TabItem">
            <Setter Property="Height" Value="48" />
            <Setter Property="Width" Value="48" />
            <Setter Property="MinHeight" Value="18" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Foreground" Value="Gray" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter VerticalAlignment="Top"
                               Content="{TemplateBinding Header}"
                               
                               TextElement.FontSize="24"
                               TextElement.FontWeight="SemiBold"
                               Foreground="{TemplateBinding Foreground}" />
                </ControlTemplate>
            </Setter>

            <Style Selector="^:pointerover">
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            </Style>

            <Style Selector="^:selected">
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            </Style>

            <Style Selector="^[IsEnabled=False]">
                <Setter Property="Foreground" Value="#20FFFFFF" />
            </Style>
        </Style>

        <Style Selector="TabControl.PageTabsView">
            <Setter Property="Template">
                <ControlTemplate>
                    <DockPanel LastChildFill="True">

                        <ItemsPresenter DockPanel.Dock="Bottom">
                            <ItemsPresenter.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel HorizontalAlignment="Center" Orientation="Horizontal" Margin="0,0" />
                                </ItemsPanelTemplate>
                            </ItemsPresenter.ItemsPanel>
                        </ItemsPresenter>
                        <TransitioningContentControl Content="{TemplateBinding SelectedContent}"
                                                     ContentTemplate="{TemplateBinding SelectedContentTemplate}" />
                    </DockPanel>
                </ControlTemplate>
            </Setter>
        </Style>

        

        <Style Selector="Slider /template/ Thumb">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid Width="20"
                          Height="20">
                        <Border Height="15"
                                Width="5"
                                HorizontalAlignment="Left"
                                CornerRadius="0"
                                BorderThickness="0"
                                Background="{DynamicResource AccentBrush}" />
                        <Border Height="5"
                                Width="15"
                                CornerRadius="0"
                                HorizontalAlignment="Right"
                                BorderThickness="0"
                                Background="Gray" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Slider[IsPointerOver=True]:pointerover /template/ Thumb">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid Width="20"
                          Height="20">
                        <Border Height="15"
                                Width="5"
                                HorizontalAlignment="Left"
                                CornerRadius="0"
                                BorderThickness="0"
                                Background="{DynamicResource AccentBrush}" />
                        <Border Height="5"
                                Width="15"
                                CornerRadius="0"
                                HorizontalAlignment="Right"
                                BorderThickness="0"
                                Background="Gray" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Slider /template/ RepeatButton#PART_IncreaseButton">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid Height="20"
                          Background="Transparent">
                        <Border Height="5"
                                Background="{DynamicResource SecondaryForegroundBrush}" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Slider /template/ RepeatButton#PART_DecreaseButton">
            <Setter Property="Template">
                <ControlTemplate>
                    <Grid Height="20"
                          Background="Transparent">
                        <Border Height="5"
                                Background="{DynamicResource AccentBrush}" />
                    </Grid>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="Button.ArrowBackButton">
            <Setter Property="Width" Value="70" />
            <Setter Property="Height" Value="70" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="35"
                            BorderThickness="4"
                            BorderBrush="{TemplateBinding BorderBrush}">
                        <ContentPresenter Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>

            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </Style>

            <Style Selector="^:pressed">
                <Setter Property="RenderTransform" Value="{x:Null}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            </Style>

            <Style Selector="^:disabled">
                <Setter Property="RenderTransform" Value="{x:Null}" />
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
            </Style>
        </Style>
    </UserControl.Styles>
    <Grid>
        <!--<ItemsControl ItemsSource="{Binding $parent[views:MainView].((viewModels:MainViewModel)DataContext).Favorites}"
                      Margin="0"
                      Effect="blur(30)"
                      Opacity="0.3"
                      IsHitTestVisible="False">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Vertical"
                               LineSpacing="10"
                               ItemSpacing="10" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Button
                        Command="{Binding $parent[views:MainView].((viewModels:MainViewModel)DataContext).PlayMediaCommand}"
                        CommandParameter="{Binding .}">
                        <Button.Template>
                            <ControlTemplate>
                                <Border Background="{DynamicResource PrimaryBackgroundBrush}"
                                        Width="150"
                                        Height="150"
                                        x:Name="AlbumArtView"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource SecondaryForegroundBrush}">
                                    <Grid>
                                        <avalonia:Icon FontSize="50"
                                                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                       Value="mdi headphones" />

                                        <Image
                                            asyncImageLoader:ImageLoader.Source="{Binding Image}"
                                            Stretch="Uniform" />
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>-->
        <Image asyncImageLoader:ImageLoader.Source="{Binding CurrentMedia.Image}"
               Stretch="UniformToFill"
               Opacity="0.7"
               Effect="blur(100)">
            <Image.OpacityMask>
                <LinearGradientBrush StartPoint="0% 0%"
                                     EndPoint="0% 100%">
                    <GradientStop Offset="0.0" Color="Transparent" />
                    <GradientStop Offset="0.01" Color="Black" />
                    <GradientStop Offset="0.7" Color="Transparent" />
                </LinearGradientBrush>
            </Image.OpacityMask>
        </Image>
        <DockPanel LastChildFill="True">
            <Border Height="48"
                    DockPanel.Dock="Top">
                <Button Classes="ArrowBackButton"
                        HorizontalAlignment="Left"
                        Margin="-20"
                        Command="{Binding $parent[views:MainView].BackButtonCommand}"
                        VerticalAlignment="Top">
                    <avalonia:Icon FontSize="58"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Value="mdi arrow-left" />
                </Button>
            </Border>
            <Border Height="140"
                    DockPanel.Dock="Bottom">
                <Grid>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Top"
                                Spacing="30"
                                Margin="30,0">
                        <Button Classes="TransportControlsButton"
                                Command="{Binding SkipPreviousCommand}">
                            <avalonia:Icon Value="mdi chevron-left" />
                        </Button>
                        <Button Classes="TransportControlsButton"
                                Command="{Binding TogglePauseCommand}"
                                Classes.IsPlaying="{Binding IsPlaying}">
                            <Button.Styles>
                                <Style Selector="Button:not(.IsPlaying)">
                                    <Setter Property="Content">
                                        <Template>
                                            <avalonia:Icon Value="mdi play" />
                                        </Template>
                                    </Setter>
                                </Style>
                                <Style Selector="Button.IsPlaying">
                                    <Setter Property="Content">
                                        <Template>
                                            <avalonia:Icon Value="mdi pause" />
                                        </Template>
                                    </Setter>
                                </Style>
                            </Button.Styles>
                        </Button>
                        <Button Classes="TransportControlsButton"
                                Command="{Binding SkipNextCommand}">
                            <avalonia:Icon Value="mdi chevron-right" />
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
            <TabControl Classes="PageTabsView"
                        Margin="0,10,0,20">
                <TabItem>
                    <TabItem.Header>
                        <avalonia:Icon Value="mdi equalizer"
                                       FontSize="30"
                                       Foreground="{Binding $parent[TabItem].Foreground}"/>
                    </TabItem.Header>
                    <Grid>
                        <DockPanel Margin="0,100,0,0">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal"
                                        >
                                <Button Classes="TransportControlsButton"
                                        Classes.IsFavorite="{Binding ((models:MediaItem)CurrentMedia).IsFavorite}"

                                        Command="{Binding ToggleFavoriteCommand}">
                                    <Button.Styles>
                                        <Style Selector="Button:not(.IsFavorite) avalonia|Icon">
                                            <Setter Property="Foreground"
                                                    Value="Gray" />
                                        </Style>
                                        <Style Selector="Button.IsFavorite avalonia|Icon">
                                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                                        </Style>
                                    </Button.Styles>
                                    <avalonia:Icon Value="mdi heart" />
                                </Button>
                            </StackPanel>
                            <Grid Width="240"
                                  Height="240"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Top">
                                <TransitioningContentControl Content="{Binding CurrentMedia}">
                                    <TransitioningContentControl.PageTransition>
                                        <Rotate3DTransition Depth="1000" SlideInEasing="CubicEaseOut" SlideOutEasing="CubicEaseOut"
                                                            Duration="0:0:0.5" />
                                    </TransitioningContentControl.PageTransition>
                                    <TransitioningContentControl.ContentTemplate>
                                        <DataTemplate>
                                            <Border Width="240"
                                                    Height="240"
                                                    x:Name="AlbumArtView"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource SecondaryForegroundBrush}"
                                                    Background="{DynamicResource PrimaryBackgroundBrush}">
                                                <Grid>
                                                    <avalonia:Icon FontSize="100"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   Value="mdi headphones" />

                                                    <Image asyncImageLoader:ImageLoader.Source="{Binding Image}"
                                                           Stretch="UniformToFill" />
                                    
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </TransitioningContentControl.ContentTemplate>
                                </TransitioningContentControl>
                                <Interaction.Behaviors>
                                    <behaviors:SwipeCommandBehavior MinSwipeDistance="50"
                                                                    SwipeLeftCommand="{Binding SkipNextCommand}"
                                                                    SwipeRightCommand="{Binding SkipPreviousCommand}"/>
                                </Interaction.Behaviors>
                            </Grid>
                            
                        </DockPanel>
                        <StackPanel VerticalAlignment="Top"
                                    Margin="0,0,0,0">
                            <TextBlock FontSize="34"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource ForegroundBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding CurrentMedia.Name, Converter={StaticResource StringCaseConverter}, ConverterParameter=u}" />
                            <TextBlock FontSize="28"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SecondaryForegroundBrush}"
                                       TextTrimming="CharacterEllipsis"
                                       Text="{Binding CurrentMedia.Artist, Converter={StaticResource StringCaseConverter}, ConverterParameter=u}" />
                        </StackPanel>
                        <DockPanel Margin="10,0"
                                   VerticalAlignment="Bottom"
                                   >
                            <TextBlock Width="30"
                                       VerticalAlignment="Center"
                                       TextAlignment="Left"
                                       HorizontalAlignment="Left"
                                       FontSize="12"
                                       Text="{Binding CurrentTime, StringFormat=m\\:ss, FallbackValue=0:00}" />
                            <TextBlock Width="30"
                                       Opacity="0.5"
                                       TextAlignment="Right"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       DockPanel.Dock="Right"
                                       Text="{Binding ((models:MediaItem)CurrentMedia).Time, StringFormat=m\\:ss, FallbackValue=0:00}" />
                            <Slider Margin="10,30"
                                    VerticalAlignment="Center"
                                    Maximum="{Binding TotalTime}"
                                    Value="{Binding Position}">
                                <Interaction.Behaviors>
                                    <behaviors:SliderDragCommandBehavior FireOnDrag="False"
                                                                         FireOnPointerPressed="True"
                                                                         DragCommand="{Binding SeekCommand}" />
                                </Interaction.Behaviors>
                            </Slider>
                        </DockPanel>
                    </Grid>

                </TabItem>
                <TabItem >
                    <TabItem.Header>
                        <avalonia:Icon Value="mdi view-list"
                                       FontSize="30"
                                       Foreground="{Binding $parent[TabItem].Foreground}"/>
                    </TabItem.Header>
                    <ScrollViewer>
                        <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding PlaylistItem.Media}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="{Binding $parent[ItemsControl].Bounds.Width}"
                                            Command="{Binding $parent[views:MainView].((viewModels:MainViewModel)DataContext).PlayMediaCommand}"
                                            CommandParameter="{Binding .}">
                                        <Button.Template>
                                            <ControlTemplate>
                                                <DockPanel LastChildFill="True" Height="50" Background="Transparent"
                                                           Margin="0,0,10,0">
                                                    <Border 
                                                            Width="20"
                                                            Height="50"
                                                            VerticalAlignment="Top"
                                                            x:Name="AlbumArtView"
                                                            BorderThickness="0"
                                                            BorderBrush="{DynamicResource SecondaryForegroundBrush}">
                                                        <Grid>
                                                            <avalonia:Icon FontSize="20"
                                                                           HorizontalAlignment="Left"
                                                                           VerticalAlignment="Top"
                                                                           Foreground="{DynamicResource ForegroundBrush}"
                                                                           Value="mdi play">
                                                                <avalonia:Icon.IsVisible>
                                                                    <MultiBinding
                                                                        Converter="{valueConverters:CurrentMediaIdIsEqualToMediaItemConverter}">
                                                                        <Binding Path="." />
                                                                        <Binding
                                                                            Path="$parent[views:MainView].((viewModels:MainViewModel)DataContext).NowPlaying.CurrentMedia" />
                                                                    </MultiBinding>
                                                                </avalonia:Icon.IsVisible>
                                                            </avalonia:Icon>
                                                        </Grid>
                                                    </Border>
                                                    <TextBlock FontSize="12"
                                                               DockPanel.Dock="Right"
                                                               Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                               Text="{Binding Time, StringFormat=m\\:ss}" />
                                                    <StackPanel Margin="8,0,0,0">

                                                        <TextBlock FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource ForegroundBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Text="{Binding Name, Converter={StaticResource StringCaseConverter}, ConverterParameter=u}" />
                                                        <TextBlock FontSize="14"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource SecondaryForegroundBrush}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Text="{Binding Artist, Converter={StaticResource StringCaseConverter}, ConverterParameter=u}" />

                                                    </StackPanel>
                                                </DockPanel>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </DockPanel>
    </Grid>

</UserControl>